" ============================================================
" LazyVim-inspired config for vanilla Vim (Git Bash on Windows)
" No external binaries required — everything here is pure
" Vimscript or shells out to tools already bundled with Git Bash
" (git, grep, find, diff).
" ============================================================

set nocompatible
filetype plugin indent on
syntax on

" ---------- Sane defaults ----------
set number relativenumber
set cursorline
set expandtab shiftwidth=2 softtabstop=2 tabstop=2
set smartindent
set ignorecase smartcase incsearch hlsearch
set wildmenu wildmode=longest:full,full
set scrolloff=8
set signcolumn=yes
set updatetime=300
set hidden                  " allow switching buffers without saving
set mouse=a                 " mouse support works fine in Git Bash's vim
set encoding=utf-8
set clipboard=unnamed       " uses Windows clipboard if +clipboard is compiled in
set backspace=indent,eol,start
set noswapfile nobackup
set undofile
if !isdirectory($HOME . "/.vim/undo")
  call mkdir($HOME . "/.vim/undo", "p")
endif
set undodir=~/.vim/undo

" leader key, LazyVim-style
let mapleader = " "
let maplocalleader = " "

" ---------- vim-plug bootstrap ----------
let data_dir = has('nvim') ? stdpath('data') . '/site' : '~/.vim'
if empty(glob(data_dir . '/autoload/plug.vim'))
  silent execute '!curl -fLo ' . data_dir . '/autoload/plug.vim --create-dirs
    \ https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim'
  autocmd VimEnter * PlugInstall --sync | source $MYVIMRC
endif

" ---------- Plugins ----------
call plug#begin('~/.vim/plugged')

" Fuzzy finding (pure vimscript, no fzf binary needed)
Plug 'ctrlpvim/ctrlp.vim'

" Git
Plug 'tpope/vim-fugitive'

" File browsing via enhanced netrw
Plug 'tpope/vim-vinegar'

" Statusline (airline = LazyVim's lualine, roughly)
Plug 'vim-airline/vim-airline'
Plug 'vim-airline/vim-airline-themes'

" Better syntax highlighting for lots of languages (regex-based,
" since we don't have Tree-sitter without Neovim)
Plug 'sheerun/vim-polyglot'

" QoL editing, LazyVim-parity
Plug 'tpope/vim-surround'
Plug 'tpope/vim-commentary'
Plug 'tpope/vim-repeat'
Plug 'jiangmiao/auto-pairs'

" which-key style popup for leader mappings
Plug 'liuchengxu/vim-which-key'

" Colorscheme
Plug 'morhetz/gruvbox'

" ---- OPTIONAL: only enable if the remote box already has a
" ---- linter/language server installed (python, powershell, etc).
" ---- ALE shells out to whatever's on PATH — it installs nothing itself.
" Plug 'dense-analysis/ale'

call plug#end()

" ---------- Colorscheme ----------
set background=dark
silent! colorscheme gruvbox

" ---------- Airline ----------
let g:airline#extensions#tabline#enabled = 1
let g:airline_theme = 'gruvbox'

" ---------- CtrlP ----------
let g:ctrlp_working_path_mode = 'ra'
let g:ctrlp_show_hidden = 1
" use git ls-files when inside a repo — much faster, no rg/fzf needed
let g:ctrlp_user_command = ['.git', 'cd %s && git ls-files -co --exclude-standard']

" ---------- which-key ----------
nnoremap <silent> <leader> :WhichKey '<Space>'<CR>

" ---------- LazyVim-ish keymaps ----------
nnoremap <leader>e :Vexplore<CR>
nnoremap <leader>ff :CtrlP<CR>
nnoremap <leader>fg :CtrlP<CR>
nnoremap <leader>gs :Git<CR>
nnoremap <leader>w :w<CR>
nnoremap <leader>q :q<CR>
nnoremap <leader><leader> :CtrlPBuffer<CR>
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

" clear search highlight
nnoremap <leader>h :nohlsearch<CR>

